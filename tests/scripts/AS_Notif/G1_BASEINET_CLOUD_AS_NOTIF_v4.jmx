              <stringProp name="script">FileWriter fWriter = new FileWriter(&quot;C:/Users/extmolivar/Desktop/Pruebas de Carga/Flujos/datos_de_usuarios_activas_v2.csv&quot;, true);
BufferedWriter buff = new BufferedWriter(fWriter);

buff.write(vars.get(&quot;P_Username&quot;)+ &quot;,&quot; + vars.get(&quot;P_CuentaMxnOrigen&quot;)+ &quot;,&quot; + vars.get(&quot;P_SaldoCuentaMxnOrigen&quot;)+ &quot;,&quot; + vars.get(&quot;P_CuentaUsdOrigen&quot;)+ &quot;,&quot; + vars.get(&quot;P_SaldoCuentaUsdOrigen&quot;)+ &quot;,&quot; + vars.get(&quot;P_CuentaMxnDestino&quot;)+ &quot;,&quot; + vars.get(&quot;P_SaldoCuentaMxnDestino&quot;)+ &quot;,&quot; + vars.get(&quot;P_CuentaUsdDestino&quot;)+ &quot;,&quot; + vars.get(&quot;P_SaldoCuentaUsdDestino&quot;)+ &quot;,&quot; + vars.get(&quot;C_FIELStatus&quot;)+&quot;\r\n&quot;);

buff.close();
fWriter.close();</stringProp>
