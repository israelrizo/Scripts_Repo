            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor - Account Checker" enabled="false">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import java.io.File
import java.io.FileWriter
import java.io.PrintWriter
import org.apache.jmeter.assertions.AssertionResult

// Get the directory where the JMX file is located
String jmxPath = props.get(&quot;jmeter.save.saveservice.output_directory&quot;);
if (jmxPath == null || jmxPath.isEmpty()) {
    jmxPath = new File(&quot;.&quot;).getCanonicalPath(); // Default to JMeter working directory
}

// Define the CSV folder path
String csvFolderPath = jmxPath + File.separator + &quot;CSV&quot;;

// Ensure the CSV directory exists
File csvFolder = new File(csvFolderPath);
if (!csvFolder.exists()) {
    csvFolder.mkdirs(); // Create the directory if it doesn&apos;t exist
}

// Define the CSV file path
String csvFilePath = csvFolderPath + File.separator + &quot;users_accounts_validation_v1.csv&quot;;
File csvFile = new File(csvFilePath);

// Header row to be included only if file is newly created
String headerRow = &quot;cuenta,nombreCompleto,Password,Token,Nombre Cliente,idCliente,idUnidadNegocio,Tipo Persona,numeroCelular,correo,idEstatus,accountStatus&quot;;

// Check if the file is newly created
boolean isNewFile = !csvFile.exists();

// Open the file and append data
FileWriter fileWriter = new FileWriter(csvFile, true);
PrintWriter printWriter = new PrintWriter(fileWriter);

// Write the header if the file is new
if (isNewFile) {
    printWriter.println(headerRow);
}
// Get username from JMeter variable
String username = vars.get(&quot;P_Username&quot;);
String nombreCompleto = vars.get(&quot;P_nombreCompleto&quot;);
String password = vars.get(&quot;P_Password&quot;);
String token = vars.get(&quot;P_Token&quot;);
String nombreCliente = vars.get(&quot;P_NombreCliente&quot;);
String idCliente = vars.get(&quot;P_idCliente&quot;);
String idUnidadNegocio = vars.get(&quot;P_idUnidadNegocio&quot;);
String tipoPersona = vars.get(&quot;P_TipoPersona&quot;);
String numeroCelular = vars.get(&quot;P_numeroCelular&quot;);
String correo = vars.get(&quot;P_correo&quot;);
String idEstatus = vars.get(&quot;P_idEstatus&quot;);

// Obtener los resultados de assertions del sampler
AssertionResult[] assertionResults = prev.getAssertionResults()

// Verificar si hay al menos uno y si falló
boolean assertionFailed = assertionResults.length &gt; 0 &amp;&amp; !assertionResults[0].isSuccessful()

// Determinar el estado de la cuenta
String accountStatus = assertionFailed ? &quot;INVALID&quot; : &quot;VALID&quot;
//
//// Get HTTP request result (true = success, false = failure)
//boolean requestSuccess = prev.isSuccessful();
//String accountStatus = requestSuccess ? &quot;VALID&quot; : &quot;INVALID&quot;;

// Create the CSV row
String csvRow = String.join(&quot;,&quot;, 
    username, nombreCompleto, password, token, nombreCliente, idCliente, 
    idUnidadNegocio, tipoPersona, numeroCelular, correo, idEstatus, accountStatus
);

// Write data to CSV
printWriter.println(csvRow);

// Close the file to ensure data is saved
printWriter.close();
fileWriter.close();

// Log for debugging
log.info(&quot;USer: &quot; + username + &quot; | Has accounts: &quot; + accountStatus);
log.info(&quot;CSV saved at: &quot; + csvFilePath);</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
